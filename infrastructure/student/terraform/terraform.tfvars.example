# Copy to terraform.tfvars (do not commit real secrets).
# Only keys listed in variables.tf for this module (infrastructure/student/terraform).

aws_region = "us-east-1"
stage      = "dev"

cognito_user_pool_id = ""
cognito_client_id    = ""

# Required: IAM role ARN for student-core Lambdas (see iam.tf / your org)
lambda_role_arn = "arn:aws:iam::123456789012:role/student-core-lambda"

enable_cloudfront    = false
student_service_path = "../../../services/student-service"

# Optional overrides (defaults exist in variables.tf)
# mentorship_external_lambda_name = "cmis-external-external-service"
# qr_signing_secret               = "change-me"
