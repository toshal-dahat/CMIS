# Example Terraform variables
# Copy this file to terraform.tfvars and customize

# AWS region where resources will be created
aws_region = "us-east-1"

# Environment name (dev, staging, prod)
environment = "dev"

# Project name (used for resource naming)
project_name = "cmis"

# Optional: Custom domain name for frontend
# domain_name = "app.example.com"

# Cognito managed by this Terraform stack
# Set Google OAuth credentials (from Google Cloud Console) if Google SSO is enabled.
enable_google_sso = true
google_oauth_client_id = "xxxxxxxxxxxx-abc123.apps.googleusercontent.com"
google_oauth_client_secret = "replace-with-secret"

# Must be globally unique in AWS Cognito domain namespace.
cognito_domain_prefix = "cmis-auth-dev"

# Include localhost callback/logout URLs for local testing.
enable_localhost_auth_callback = true
#additional_cognito_callback_urls = []
#additional_cognito_logout_urls   = []

# Use SES for Cognito emails (OTP, verification, etc.) to avoid Cognito default limits.
# Step 1: set sender identity and keep enable_cognito_ses_email=false, then apply.
# Step 2: verify SES email in inbox, set enable_cognito_ses_email=true, then apply again.
# enable_cognito_ses_email = false
# Preferred: provide identity name and let Terraform auto-build ARN.
# cognito_ses_identity_name = "example.com" # or "no-reply@example.com"
# Optional override: set explicit ARN instead of identity name.
# cognito_ses_source_arn = "arn:aws:ses:us-east-1:123456789012:identity/example.com"
# cognito_from_email_address = "no-reply@example.com"
# cognito_reply_to_email_address = "support@example.com"

# Keep empty when Cognito is in the same AWS account.
#cognito_admin_role_arn = ""
#cognito_admin_external_id = ""

# Optional: force one email into Cognito "admins" group on first grouped API call.
#admin_override_email = "your-admin@tamu.edu"
